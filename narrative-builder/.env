# Narrative Builder Configuration File
# Copy this file to .env and customize your settings

# ============================================
# Data Loading Configuration
# ============================================

# Default path to news dataset JSON file
DEFAULT_DATA_PATH="news_dataset.json"

# Minimum source rating threshold (0-10)
MIN_SOURCE_RATING=8.0

# Use streaming parser for large files (true/false)
STREAMING_PARSER=true


# ============================================
# Embedding Model Configuration
# ============================================

# Embedding model name from sentence-transformers
# Options:
#   - all-MiniLM-L6-v2 (fast, 384 dim, ~80MB)
#   - all-mpnet-base-v2 (balanced, 768 dim, ~420MB) [RECOMMENDED]
#   - BAAI/bge-large-en-v1.5 (best quality, 1024 dim, ~1.3GB)
EMBEDDING_MODEL="BAAI/bge-small-en-v1.5"

# Batch size for embedding generation (higher = faster but more memory)
EMBEDDING_BATCH_SIZE=32

# Maximum text length for embedding (in tokens)
EMBEDDING_MAX_LENGTH=512

# Normalize embeddings for cosine similarity (true/false)
NORMALIZE_EMBEDDINGS=true


# ============================================
# Vector Index Configuration
# ============================================

# FAISS index type: auto, flat, ivf
# - auto: automatically choose based on dataset size
# - flat: exact search (best for <100k articles)
# - ivf: approximate search (best for >100k articles)
FAISS_INDEX_TYPE="auto"

# Number of clusters for IVF index (null for auto-calculate)
FAISS_IVF_NLIST=null

# Number of clusters to search in IVF index
FAISS_IVF_NPROBE=10

# Use GPU acceleration if available (true/false)
# Requires faiss-gpu installation
FAISS_USE_GPU=false


# ============================================
# Search Configuration
# ============================================

# Default number of articles to retrieve
DEFAULT_TOP_K=50

# Minimum similarity threshold (0.0-1.0)
# Set to 0.0 to retrieve all results
SIMILARITY_THRESHOLD=0.8


# ============================================
# Clustering Configuration
# ============================================

# Clustering method: keyword, kmeans, dbscan
CLUSTERING_METHOD="keyword"

# Minimum number of articles per cluster
MIN_CLUSTER_SIZE=2

# Maximum number of clusters to create
MAX_CLUSTERS=10


# ============================================
# Narrative Generation Configuration
# ============================================

# Minimum sentences in narrative summary
SUMMARY_MIN_SENTENCES=5

# Maximum sentences in narrative summary
SUMMARY_MAX_SENTENCES=10

# Timeline sorting: date, relevance
TIMELINE_SORT="date"

# Include relationship graph in output (true/false)
INCLUDE_GRAPH=true


# ============================================
# Performance Configuration
# ============================================

# Directory for caching embeddings and indexes
CACHE_DIR="./cache"

# Enable caching (true/false)
ENABLE_CACHE=true

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL="INFO"

# Number of worker threads for parallel processing
NUM_WORKERS=4


# ============================================
# Output Configuration
# ============================================

# Output format: json, yaml
OUTPUT_FORMAT="json"

# JSON indentation level
OUTPUT_INDENT=2

# Include metadata in output (true/false)
INCLUDE_METADATA=true
