# Semantic Search Configuration

# Embedding Model Configuration
# Options: 'all-MiniLM-L6-v2' (fast, 384-dim), 'all-mpnet-base-v2' (quality, 768-dim), 'BAAI/bge-small-en-v1.5' (sota)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Device Configuration
# Options: 'cuda' (GPU), 'cpu' (CPU), 'auto' (auto-detect)
DEVICE=cuda

# FAISS Configuration
USE_GPU=true

# Search Configuration
DEFAULT_TOP_K=5
DEFAULT_OUTPUT_FORMAT=json

# Paths
POSTMAN_COLLECTION_PATH=postman-twitter-api/Twitter API v2.postman_collection.json
INDEX_DIR=index
